rules_version = '2';

service firebase.storage {
	match /b/{bucket}/o {
		match /users/{userId}/{allPaths=**} {
			allow read, write: if false;
		}

		match /anonymous/{anonymousUid}/{allPaths=**} {
			allow read, write: if false;
		}

		match /exams/{examId}/{allPaths=**} {
			allow read, write: if false;
		}

		match /{allPaths=**} {
			allow read, write: if false;
		}
	}
}
