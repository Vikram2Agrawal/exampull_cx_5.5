{
	"firestore": {
		"rules": "firestore.rules",
		"indexes": "firestore.indexes.json"
	},
	"storage": {
		"rules": "storage.rules"
	},
	"apphosting": {
		"backendId": "exampull-web",
		"rootDir": "/",
		"ignore": [
			"node_modules",
			".git",
			".next",
			"test-results",
			"playwright-report",
			"coverage",
			"firebase-debug.log",
			"firebase-debug.*.log"
		],
		"alwaysDeployFromSource": true
	},
	"emulators": {
		"auth": {
			"port": 9099
		},
		"firestore": {
			"port": 8080
		},
		"storage": {
			"port": 9199
		},
		"ui": {
			"enabled": true,
			"port": 4000
		}
	}
}
