# ===========================================
# ExamPull Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ===========================================

# ----- Firebase (client-side, embedded in browser bundle) -----
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxx
# Optional — Google Analytics measurement ID, present when the Firebase Web App
# was created with Analytics enabled (format: G-XXXXXXXXXX)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ----- Firebase Admin (server-side only) -----
# Path to the service account JSON key file (relative to project root).
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=.service-account-key.json

# ----- Google Cloud -----
# GCP project ID (same as Firebase project).
GOOGLE_CLOUD_PROJECT=your-project-id
# Primary region for Cloud Run, Cloud Tasks, Vertex AI.
GOOGLE_CLOUD_REGION=us-central1
# Cloud Tasks worker queue and OIDC invoker.
CLOUD_TASKS_QUEUE=exampull-jobs
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_INVOKER_SA=exampull-tasks@your-project-id.iam.gserviceaccount.com
CLOUD_TASKS_AUTH_REQUIRED=true

# ----- Stripe -----
# Secret key — starts with sk_test_ (test) or sk_live_ (production).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Webhook signing secret — starts with whsec_.
# Obtain via: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Publishable key — starts with pk_test_ (test) or pk_live_ (production).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — generated by: pnpm setup:stripe
# If not set, placeholder strings are used (fine for local dev without real Stripe).
STRIPE_PRICE_SCHOLAR_MONTHLY=price_scholar_monthly
STRIPE_PRICE_SCHOLAR_ANNUAL=price_scholar_annual
STRIPE_PRICE_GURU_MONTHLY=price_guru_monthly
STRIPE_PRICE_GURU_ANNUAL=price_guru_annual
# Legacy V1 credit price IDs — DEPRECATED, retained only for reference.
# Current credit packs are STRIPE_PRICE_CREDITS_20/100/240 below (PRD v2 — 1 credit = 1 question).
# New code MUST use the V2 keys; the V1 keys exist only so leftover V1 webhook payloads do not crash.
STRIPE_PRICE_CREDIT_1=price_credit_1
STRIPE_PRICE_CREDIT_5=price_credit_5
STRIPE_PRICE_CREDIT_12=price_credit_12
# Current credit pricing per PRD v2 (1 credit = 1 question, $0.05/credit base).
STRIPE_PRICE_CREDITS_20=price_credits_20
STRIPE_PRICE_CREDITS_100=price_credits_100
STRIPE_PRICE_CREDITS_240=price_credits_240
# Restricted Stripe key for refund-only operations from the admin dashboard.
# Created in the Stripe Dashboard (Developers → API keys → Create restricted key).
STRIPE_RESTRICTED_KEY_REFUNDS=rk_test_xxxxxxxxxxxxxxxxxxxx

# ----- LaTeX Compilation Service -----
# Local: http://localhost:8080 (via docker compose)
# Production: Cloud Run service URL (e.g., https://latex-service-xxxxx-uc.a.run.app)
LATEX_SERVICE_URL=http://localhost:8080
# Set true only for a local unauthenticated LaTeX service.
LATEX_SERVICE_AUTH_DISABLED=true

# ----- Web URL (Firebase App Hosting backend URL) -----
# Used by Cloud Tasks to call back into the Next.js app worker routes.
# Local: http://localhost:3000
# Deployed: the URL emitted by `firebase apphosting:backends:create` (e.g., https://exampull--exampull.us-central1.hosted.app)
WEB_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# ----- Featurebase (Feedback & Roadmap) -----
# JWT secret for SSO — get from Featurebase Settings → Security → Get JWT Secret
FEATUREBASE_JWT_SECRET=your-featurebase-jwt-secret
# Organization slug — visible in your Featurebase dashboard URL
NEXT_PUBLIC_FEATUREBASE_ORGANIZATION=your-featurebase-org-slug

# ----- Feature Flags -----
NEXT_PUBLIC_ENABLE_POWER_MODE=true
NEXT_PUBLIC_ENABLE_VISUAL_FEEDBACK=true

# ----- OpenRouter (LLM gateway) -----
# Single API surface across 300+ models; replaces direct Vertex AI calls.
# Get key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ----- Resend (transactional email) -----
# Default sender uses Resend's onboarding domain (`onboarding@resend.dev`) — works without
# DNS verification. Swap RESEND_FROM_ADDRESS to a verified custom sender once the operator
# wires up a sending domain post-launch.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_ADDRESS=onboarding@resend.dev
RESEND_DOMAIN_ID=                            # Optional; only needed if a verified domain is configured

# ----- Twilio (SMS) -----
# Used for admin auth fallback + admin broadcasts.
# User signup phone verification uses Firebase Auth's built-in SMS, not Twilio directly.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_USER_SID=USxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550100

# ----- Porkbun (DNS) -----
# Used for programmatic DNS management when adding/verifying email domains, etc.
PORKBUN_API_KEY=pk1_xxxxxxxxxxxxxxxxxxxx
PORKBUN_SECRET_KEY=sk1_xxxxxxxxxxxxxxxxxxxx

# ----- Admin (path-based at ${WEB_URL}/admin/* during build phase) -----
ADMIN_EMAIL=you@example.com
ADMIN_PHONE_NUMBER=+15555550100
ADMIN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Hostname the WebAuthn relying party is registered against. During build phase this is
# the App Hosting backend hostname; post-launch this becomes the custom admin host (if any).
ADMIN_WEBAUTHN_RP_ID=
# Agent auth path — unblocks autonomous loops that can't do passkey/SMS interactively.
# Strong password; empty = path disabled. Read-only / idempotent ops only — destructive
# ops still require passkey or SMS step-up. See admin-prd.md §2 "Agent Password Path".
ADMIN_AGENT_PASSWORD=
ADMIN_AGENT_AUTH_ENABLED=true

# Test signup token — gates test account creation (PRD §5.19). Empty in production.
TEST_SIGNUP_TOKEN=
